#include <iostream>
#include <set>

using namespace std;

int main() {
    int q; // Number of queries
    if (!(cin >> q)) return 0;
    
    set<int> s; // Our container for unique integers
    
    while (q--) {
        int type, x;
        cin >> type >> x;
        
        if (type == 1) {
            // Add x to the set
            s.insert(x);
        } 
        else if (type == 2) {
            // Erase x from the set
            s.erase(x);
        } 
        else if (type == 3) {
            // Check if x exists
            if (s.find(x) != s.end()) {
                cout << "Yes" << endl;
            } else {
                cout << "No" << endl;
            }
        }
    }
    
    return 0;
}
