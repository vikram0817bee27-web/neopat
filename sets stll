#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <set>
#include <algorithm>
using namespace std;


int main() {
    /* Enter your code here. Read input from STDIN. Print output to STDOUT */  
     int q;
    cin >> q;
    
    set<int> s;
    
    while(q--) {
        int type, x;
        cin >> type >> x;
        
        if (type == 1) {
            // Add x to the set
            s.insert(x);
        } else if (type == 2) {
            // Erase x from the set (if it exists)
            s.erase(x);
        } else if (type == 3) {
            // Check if x is present
            if (s.find(x) != s.end()) {
                cout << "Yes" << endl;
            } else {
                cout << "No" << endl;
            }
        }
    }
     
    return 0;
}
