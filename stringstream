#include <iostream>
#include <vector>
#include <sstream>
using namespace std;

int main() {
    string line;
    cin >> line;
    stringstream ss(line);
    
    int num;
    char comma;
    
    // Read integer, then skip the comma if it exists
    while (ss >> num) {
        cout << num << endl;
        ss >> comma; 
    }
    
    return 0;
}
